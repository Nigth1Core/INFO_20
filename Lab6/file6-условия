%Управляющие структуры ветвления
function message = Decade(d)
if (d>=21) && (d<=31) 
    message = sprintf('Число %d попадает в третью декаду месяца',d);
else
    message = sprintf('Число %d не попадает в третью декаду месяца',d);
end
end

